#!/bin/bash
set -e

pnpm install --frozen-lockfile

if [ "$#" -eq 0 ]; then
  exit 0
fi

MSG=$(git log -1 --format="%s")

# Skip for merge commits, chore commits, or amend-only pushes
if echo "$MSG" | grep -qE '^(chore:|Merge )'; then
  exit 0
fi

# Determine bump type from commit message
if echo "$MSG" | grep -qE '^feat(\(.+\))?:'; then
  BUMP="minor"
else
  BUMP="patch"
fi

EXPECTED_VERSION=$(node -e "
  const fs = require('fs');
  const parentPkg = JSON.parse(require('child_process').execFileSync('git', ['show', 'HEAD^:package.json'], { encoding: 'utf8' }));
  const [major, minor, patch] = parentPkg.version.split('.').map(Number);
  process.stdout.write('$BUMP' === 'minor'
    ? \`\${major}.\${minor + 1}.0\`
    : \`\${major}.\${minor}.\${patch + 1}\`);
")

CURRENT_VERSION=$(node -e "
  const fs = require('fs');
  const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
  process.stdout.write(pkg.version);
")

if [ "$CURRENT_VERSION" = "$EXPECTED_VERSION" ]; then
  exit 0
fi

# Bump version in package.json without creating a git tag
node -e "
  const fs = require('fs');
  const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
  pkg.version = '$EXPECTED_VERSION';
  fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2) + '\n');
  console.log('Version bumped to ' + pkg.version);
"

# Amend the current commit to include the version bump
git add package.json
git commit --amend --no-edit --no-verify -q
echo "Version bump amended into commit. Run git push again."
exit 1
